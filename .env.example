# ME — Plantilla de configuración
# ─────────────────────────────────────────────────────────────
# Copia este archivo a .env antes de ejecutar:
#   cp .env.example .env
#
# .env NUNCA se commitea. Cada instalación tiene el suyo.

# ─── Backend ─────────────────────────────────────────────────

ME_PORT=8082
ME_DB_PATH=./me.db
ME_VAULT_PATH=./vault
ME_INIT_PATH=./ME-Init.md

# ─── Ollama — OPCIONAL ───────────────────────────────────────
# El chat con LLM requiere una máquina capaz de correr modelos locales.
# Si no tienes Ollama, deja estas variables vacías o coméntalas.
# El sistema funciona completo sin esto (memorias, búsqueda, esfera).
#
# Para activar:
#   1. Instala Ollama: https://ollama.ai
#   2. Descarga un modelo: ollama pull mistral
#   3. Descomenta las líneas de abajo y reinicia
#
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=mistral
#
# Modelos recomendados según tu hardware:
#   8GB RAM  → phi3, gemma2:2b
#   16GB RAM → mistral, llama3.2
#   32GB RAM → llama3.1:8b, qwen2.5:7b

# ─── Frontend ────────────────────────────────────────────────

# Debe coincidir con ME_PORT
NEXT_PUBLIC_API_URL=http://localhost:8082

# ─── Extensiones futuras ─────────────────────────────────────
# Agrega aquí las variables al extender el sistema.

# MCP server
# MCP_PORT=8083

# APIs externas
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=

# Supabase (para Morgana / multi-usuario)
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
